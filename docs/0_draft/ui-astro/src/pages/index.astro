                        </div>
                      </div>
                      <div class="demo-dp-choice">Tùy bạn chọn — không ép một phương án</div>
                    </div>
                  )
                ) : (
                  <>demo — placeholder</>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}

